target base;
build {
  optimize O1;
  scheduler safe;
  scheduler_window 1;
  memory_reorder strict;
}
// Note: registers are local per PE; cross-PE dataflow still requires explicit routing/incoming semantics.
function s0(v) {
  bundle { at @0,0: SADD R1, v, ZERO; }
}
function s1(v) {
  bundle { at @0,1: SADD R2, v, R1; }
}
function s2(v) {
  bundle { at @0,2: SADD R3, v, R2; }
}
kernel "pipeline_adv" {
  pipeline(s0(R0), s1(R0), s2(R0));
}
